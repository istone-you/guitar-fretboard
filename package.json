{
  "name": "guitar-fretboard-interactive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "check": "vp check",
    "typecheck": "tsgo --noEmit",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "test": "vp test run",
    "coverage": "vp test run --coverage",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "deploy": "bun run build && wrangler pages deploy dist --project-name=guitar-fretboard"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript/native-preview": "^7.0.0-dev.20260327.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.8.9",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^8.0.3",
    "vite-plus": "^0.1.14",
    "wrangler": "^4.77.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.10"
}
